<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema de Levantamento ISPS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-slate-900 min-h-screen p-2 md:p-6 text-slate-800">

    <div class="max-w-4xl mx-auto bg-white rounded-2xl shadow-2xl overflow-hidden border border-slate-700">
        <div class="bg-slate-800 p-6 border-b-4 border-blue-500">
            <h1 class="text-white text-xl font-black uppercase tracking-widest flex items-center gap-3">
                <i class="fas fa-hard-hat text-blue-400"></i>
                Levantamento de Materiais
            </h1>
            <p class="text-slate-400 text-xs mt-1 font-bold uppercase">Controle de Acesso - ISPS 2026</p>
        </div>

        <div class="p-4 md:p-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8 bg-slate-50 p-4 rounded-xl border border-slate-200">
                <div>
                    <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Responsável</label>
                    <select id="responsavel" class="w-full border-slate-300 rounded-lg p-3 bg-white shadow-sm focus:ring-2 focus:ring-blue-500 outline-none font-bold text-slate-700">
                        <option value="">Selecione o condutor...</option>
                        <option value="Adriano Nascimento">Adriano Nascimento</option>
                        <option value="Deivison Aleidson">Deivison Aleidson</option>
                        <option value="Deivison Barros">Deivison Barros</option>
                        <option value="Francivaldo">Francivaldo</option>
                    </select>
                </div>
                <div>
                    <label class="block text-[10px] font-black text-slate-400 uppercase mb-1">Local da Obra</label>
                    <input type="text" id="local" placeholder="Ex: Píer / Castelo D'água" class="w-full border-slate-300 rounded-lg p-3 bg-white shadow-sm focus:ring-2 focus:ring-blue-500 outline-none font-bold">
                </div>
            </div>

            <div id="lista-container" class="space-y-4">
                </div>

            <div class="mt-10 flex flex-wrap gap-4 border-t border-slate-100 pt-8">
                <button onclick="addLinha()" class="flex-1 bg-slate-800 hover:bg-slate-700 text-white font-black py-4 px-6 rounded-xl flex items-center justify-center gap-2 transition-all active:scale-95 shadow-lg">
                    <i class="fas fa-plus-circle text-blue-400 text-lg"></i> ADICIONAR ITEM
                </button>

                <button onclick="gerarRelatorio()" class="flex-1 bg-green-600 hover:bg-green-700 text-white font-black py-4 px-6 rounded-xl flex items-center justify-center gap-2 transition-all active:scale-95 shadow-lg">
                    <i class="fab fa-whatsapp text-lg"></i> ENVIAR WHATSAPP
                </button>
            </div>
        </div>
    </div>

    <datalist id="materiais-list">
        <option value="Eletroduto Galvanizado a fogo Ø1\" NBR 5598">
        <option value="Curva 90° Galvanizado a fogo Ø1\"">
        <option value="Cabo de fibra óptica DDR, SM, 12FO">
        <option value="Conversor de Mídia 10/100/1000 - SM - SC">
        <option value="Painel elétrico IP65 com placa de montagem">
        <option value="Eletroduto flexível (Sealtubo) Ø1\"">
        <option value="Disjuntor 10A - Termomagnético-Bifásico">
        <option value="Cabo elétrico PP 3x6mm">
        <option value="Cabo elétrico PP 3x2,5mm">
        <option value="Conector RJ45 Macho CAT6">
